{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dlc://schemas/memory.schema.json",
  "title": "Memory Module",
  "description": "Memory system module. Required for L2+ (depends on engine).",
  "type": "object",
  "required": [
    "enabled"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Enable memory module (L2+)."
    },
    "architecture": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^memory/architecture\\.json$",
      "description": "Path to memory architecture config."
    },
    "schedule": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^memory/schedule\\.json$",
      "description": "Path to memory schedule config."
    }
  }
}